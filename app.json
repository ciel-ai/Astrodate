{
  "expo": {
    "name": "AstroDate",
    "slug": "astrodate",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-v2.png",
    "scheme": "astrodate",
    "userInterfaceStyle": "dark",
    "ios": {
      "usesAppleSignIn": true,
      "buildNumber": "2",
      "supportsTablet": false,
      "bundleIdentifier": "com.cielinfitech.astrodate",
      "infoPlist": {
        "NSCameraUsageDescription": "AstroDate needs access to your camera so you can take profile photos and capture pictures to share in chats.",
        "NSPhotoLibraryUsageDescription": "AstroDate needs access to your photo library so you can choose pictures for your profile and share them in chats.",
        "NSMicrophoneUsageDescription": "AstroDate needs access to your microphone so you can record and send voice messages in chats.",
        "NSLocationWhenInUseUsageDescription": "AstroDate uses your location to auto-fill your city and to show matches near you. Your exact location is never shared with other users.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "AstroDate uses your device identifier to measure subscription analytics via RevenueCat and personalise your match recommendations. Your data is never shared with advertisers.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": [
              "C617.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": [
              "E174.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": [
              "35F9.1"
            ]
          }
        ]
      }
    },
    "android": {
      "versionCode": 2,
      "package": "com.astrodate.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground-v2.png",
        "backgroundImage": "./assets/images/android-icon-background-v2.png",
        "monochromeImage": "./assets/images/android-icon-monochrome-v2.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "astrodate",
              "host": "auth",
              "pathPrefix": "/verify"
            },
            {
              "scheme": "astrodate",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-v2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true,
            "kotlinVersion": "2.0.21",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          },
          "ios": {
            "privacyManifestAggregationEnabled": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-v2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#04020b",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "AstroDate needs access to your photo library so you can choose pictures for your profile and share them in chats.",
          "cameraPermission": "AstroDate needs access to your camera so you can take profile photos and capture pictures to share in chats.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AstroDate uses your location to auto-fill your city and to show matches near you. Your exact location is never shared with other users."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "AstroDate needs access to your microphone so you can record and send voice messages in chats."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-asset",
      "expo-notifications",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "We use your device identifier to measure app performance and improve your recommendations."
        }
      ],
      "expo-apple-authentication",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0316ec04-75d5-4ab8-ab58-ac9f33069d28"
      }
    },
    "owner": "ciel.ai"
  }
}