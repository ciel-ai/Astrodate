# Copy this file to .env and fill in your values.
# Never commit .env to git — it is listed in .gitignore.
# For production builds, set these as EAS Secrets in your Expo dashboard.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Email Verification Deep Link ────────────────────────────────────────────
# This is the URL Supabase redirects to after the user clicks the email link.
# For Expo Go (development): use exp://127.0.0.1:8081/--/auth/verify
# For production builds:     use astrodate://auth/verify
#
# You must add BOTH of these to Supabase Dashboard:
#   Authentication → URL Configuration → Redirect URLs
#
# EXPO_PUBLIC_EMAIL_REDIRECT_URL=astrodate://auth/verify
